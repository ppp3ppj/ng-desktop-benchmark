{
  "name": "ng-electron",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:build": "ng build --configuration electron && bun run electron:compile",
    "electron:start": "electron .",
    "electron:dev": "bun run electron:build && electron .",
    "dist:win": "bun run electron:build && electron-builder --win",
    "dist:mac": "bun run electron:build && electron-builder --mac",
    "dist:linux": "bun run electron:build && electron-builder --linux"
  },
  "build": {
    "appId": "com.ng-electron.app",
    "productName": "NgElectron",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/ng-electron/browser/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/icons/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icons/icon.png"
    }
  },
  "private": true,
  "packageManager": "bun@1.3.13",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "daisyui": "^5.5.19",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}